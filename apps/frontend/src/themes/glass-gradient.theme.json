{
  "schemaVersion": 1,
  "meta": {
    "id": "glass-gradient",
    "name": "Glass Gradient",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Default frosted glass theme with layered cyan-blue gradients."
