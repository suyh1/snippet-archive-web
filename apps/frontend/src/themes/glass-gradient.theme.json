      "sidebarBackground": "radial-gradient(circle at 14% 12%, rgba(125, 211, 252, 0.24), transparent 45%), radial-gradient(circle at 80% 100%, rgba(20, 184, 166, 0.2), transparent 40%), linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(30, 41, 59, 0.9))",
