{
  "schemaVersion": 1,
  "meta": {
    "id": "lava-forge",
    "name": "Lava Forge",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "熔岩锻造风格，黑曜底色叠加赤焰与铜金高光。"
  },
