      "toolbarLinkHoverBorder": "rgba(234, 179, 8, 0.72)",
      "toolbarLinkHoverBackground": "rgba(76, 33, 16, 0.74)",
      "toolbarLinkActiveBorder": "rgba(239, 68, 68, 0.76)",
      "toolbarLinkActiveBackground": "rgba(153, 27, 27, 0.56)",
      "toolbarLinkActiveText": "#ffedd5",
