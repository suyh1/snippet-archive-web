{
  "schemaVersion": 1,
  "meta": {
    "id": "paper-ink",
    "name": "Paper & Ink",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Soft paper-like light theme optimized for long reading sessions."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'IBM Plex Sans', 'Noto Sans SC', 'Segoe UI', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #f8f6ef 0%, #f0ece1 100%)",
      "appShellBackground": "radial-gradient(circle at 12% 9%, rgba(148, 163, 184, 0.16), transparent 44%), radial-gradient(circle at 86% 0%, rgba(251, 191, 36, 0.12), transparent 42%), linear-gradient(160deg, #f6f3e8 0%, #f2eee3 54%, #ece6d8 100%)",
      "sidebarBackground": "linear-gradient(180deg, rgba(31, 41, 55, 0.96), rgba(55, 65, 81, 0.92))",
      "sidebarText": "#f3f4f6",
      "sidebarBorder": "rgba(107, 114, 128, 0.4)"
    },
    "text": {
      "primary": "#1f2937",
      "secondary": "#374151",
      "tertiary": "#4b5563",
      "inverse": "#f8fafc",
      "accent": "#1d4ed8",
      "muted": "#6b7280",
      "danger": "#991b1b",
      "dangerStrong": "#7f1d1d"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(255, 252, 244, 0.86), rgba(245, 239, 225, 0.62))",
      "glassPanelBorder": "rgba(217, 206, 179, 0.62)",
      "glassPanelShadow": "0 16px 28px rgba(120, 113, 108, 0.16)",
      "glassCardBackground": "linear-gradient(140deg, rgba(255, 253, 248, 0.9), rgba(245, 239, 225, 0.66))",
      "glassTileBackground": "linear-gradient(145deg, rgba(255, 252, 244, 0.9), rgba(243, 238, 226, 0.7))",
      "glassTileBorder": "rgba(217, 206, 179, 0.65)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(254, 243, 199, 0.42), rgba(243, 244, 246, 0.58))",
      "ghostButtonBackground": "rgba(255, 252, 244, 0.88)",
      "neutralButtonBackground": "rgba(250, 246, 236, 0.86)",
      "neutralButtonBorder": "rgba(161, 161, 170, 0.5)",
      "inputBackground": "rgba(255, 252, 244, 0.94)",
      "inputBorder": "rgba(161, 161, 170, 0.52)",
      "codeTagBackground": "rgba(214, 211, 209, 0.42)",
      "statusbarBackground": "rgba(248, 250, 252, 0.66)",
      "statusbarBorder": "rgba(148, 163, 184, 0.3)",
      "emptyStateBackground": "rgba(255, 255, 255, 0.45)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(186, 230, 253, 0.55)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(191, 219, 254, 0.56)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(224, 242, 254, 0.45)",
      "rootDropzoneActiveBackground": "rgba(186, 230, 253, 0.6)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(7, 11, 28, 0.45)",
      "overlayStrongBackground": "rgba(15, 23, 42, 0.42)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.85))",
      "toastBorder": "rgba(148, 163, 184, 0.35)",
      "toastShadow": "0 14px 28px rgba(15, 23, 42, 0.28)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(29, 78, 216, 0.9), rgba(59, 130, 246, 0.84))",
      "primaryButtonBorder": "rgba(37, 99, 235, 0.56)",
      "primaryButtonText": "#f8fafc",
      "actionButtonBorder": "rgba(148, 163, 184, 0.48)",
      "actionButtonBackground": "rgba(241, 245, 249, 0.7)",
      "actionButtonText": "#334155",
      "selectedBorder": "rgba(29, 78, 216, 0.5)",
      "selectedBackground": "rgba(59, 130, 246, 0.16)",
      "selectedText": "#1e40af",
      "focusBorder": "rgba(56, 189, 248, 0.85)",
      "focusRing": "rgba(56, 189, 248, 0.35)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(56, 189, 248, 0.95), rgba(45, 212, 191, 0.86))",
      "sidebarPrimaryBorder": "rgba(56, 189, 248, 0.55)",
      "sidebarPrimaryText": "#082f49",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
      "sidebarGhostBorder": "rgba(186, 230, 253, 0.36)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(56, 189, 248, 0.58)",
      "rowActionBackground": "rgba(14, 165, 233, 0.16)",
      "rowActionText": "#0f172a"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
  }
}
