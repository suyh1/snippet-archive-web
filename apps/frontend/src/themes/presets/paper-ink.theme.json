{
  "schemaVersion": 1,
  "meta": {
    "id": "paper-ink",
    "name": "Paper & Ink",
    "version": "1.1.0",
    "author": "Snippet Archive",
    "description": "纸墨主题，温和米白与墨色适合内容创作场景。"
  },
