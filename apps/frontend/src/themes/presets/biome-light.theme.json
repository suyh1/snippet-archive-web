{
  "schemaVersion": 1,
  "meta": {
    "id": "biome-light",
    "name": "Biome Light",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "有机浅色主题，薄荷与珊瑚形成轻盈生态感。"
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Syne', 'DM Sans', 'Noto Sans SC', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #fbfff8 0%, #edf9f3 100%)",
      "appShellBackground": "radial-gradient(circle at 12% 8%, rgba(52, 211, 153, 0.2), transparent 40%), radial-gradient(circle at 84% 4%, rgba(45, 212, 191, 0.18), transparent 38%), radial-gradient(circle at 50% 100%, rgba(251, 146, 60, 0.16), transparent 44%), linear-gradient(160deg, #eefcf5 0%, #e8f8ef 52%, #e2f5eb 100%)",
      "sidebarBackground": "linear-gradient(180deg, rgba(2, 44, 34, 0.98), rgba(6, 78, 59, 0.94))",
      "sidebarText": "#ccfbf1",
      "sidebarBorder": "rgba(94, 234, 212, 0.34)"
    },
    "text": {
      "primary": "#03342a",
      "secondary": "#065f46",
      "tertiary": "#0f766e",
      "inverse": "#f8fffb",
      "accent": "#0f766e",
      "muted": "#4b5563",
      "danger": "#9f1239",
      "dangerStrong": "#881337"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(255, 255, 255, 0.78), rgba(187, 247, 208, 0.42))",
      "glassPanelBorder": "rgba(167, 243, 208, 0.68)",
      "glassPanelShadow": "0 18px 34px rgba(3, 46, 33, 0.16)",
      "glassCardBackground": "linear-gradient(140deg, rgba(255, 255, 255, 0.86), rgba(220, 252, 231, 0.56))",
      "glassTileBackground": "linear-gradient(145deg, rgba(255, 255, 255, 0.8), rgba(204, 251, 241, 0.54))",
      "glassTileBorder": "rgba(167, 243, 208, 0.62)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(167, 243, 208, 0.56), rgba(253, 230, 138, 0.28))",
      "ghostButtonBackground": "rgba(255, 255, 255, 0.84)",
      "neutralButtonBackground": "rgba(236, 253, 245, 0.84)",
      "neutralButtonBorder": "rgba(52, 211, 153, 0.46)",
      "inputBackground": "rgba(255, 255, 255, 0.92)",
      "inputBorder": "rgba(45, 212, 191, 0.44)",
      "codeTagBackground": "rgba(167, 243, 208, 0.42)",
      "statusbarBackground": "rgba(236, 253, 245, 0.82)",
      "statusbarBorder": "rgba(45, 212, 191, 0.34)",
      "emptyStateBackground": "rgba(236, 253, 245, 0.56)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(45, 212, 191, 0.2)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(251, 146, 60, 0.2)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(187, 247, 208, 0.4)",
      "rootDropzoneActiveBackground": "rgba(45, 212, 191, 0.24)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(2, 44, 34, 0.5)",
      "overlayStrongBackground": "rgba(2, 44, 34, 0.56)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(4, 47, 46, 0.92), rgba(8, 74, 61, 0.86))",
      "toastBorder": "rgba(94, 234, 212, 0.36)",
      "toastShadow": "0 16px 30px rgba(3, 41, 30, 0.3)",
      "toolbarGlassBorder": "rgba(94, 234, 212, 0.42)",
      "toolbarGlassBackground": "radial-gradient(128% 188% at 12% -30%, rgba(52, 211, 153, 0.24) 0%, rgba(52, 211, 153, 0) 54%), radial-gradient(136% 196% at 88% -44%, rgba(251, 146, 60, 0.2) 0%, rgba(251, 146, 60, 0) 56%), var(--theme-surface-glass-header-background)",
      "toolbarGlassBackdropFilter": "blur(24px) saturate(1.3) contrast(1.04)",
      "toolbarGlassShadow": "0 20px 38px rgba(2, 52, 44, 0.34), 0 8px 20px rgba(11, 124, 95, 0.26), inset 0 1px 0 rgba(219, 255, 241, 0.42), inset 0 -1px 0 rgba(57, 134, 105, 0.28)",
      "toolbarGlassHighlightArc": "radial-gradient(103% 93% at 50% 100%, rgba(236, 255, 248, 0.54) 0%, rgba(236, 255, 248, 0.22) 36%, rgba(236, 255, 248, 0.08) 56%, rgba(236, 255, 248, 0) 74%)",
      "toolbarGlassTintOverlay": "radial-gradient(circle at 16% 84%, rgba(45, 212, 191, 0.2), rgba(45, 212, 191, 0) 44%), radial-gradient(circle at 84% 86%, rgba(251, 146, 60, 0.16), rgba(251, 146, 60, 0) 46%)",
      "toolbarTitleText": "var(--theme-text-secondary)",
      "toolbarLinkBorder": "rgba(52, 211, 153, 0.54)",
      "toolbarLinkBackground": "rgba(9, 67, 55, 0.56)",
      "toolbarLinkText": "#d1fae5",
      "toolbarLinkInsetShadow": "inset 0 1px 0 rgba(200, 252, 233, 0.3), inset 0 -1px 0 rgba(45, 110, 89, 0.26)",
      "toolbarLinkHoverBorder": "rgba(52, 211, 153, 0.7)",
      "toolbarLinkHoverBackground": "rgba(13, 98, 77, 0.66)",
      "toolbarLinkActiveBorder": "rgba(251, 146, 60, 0.72)",
      "toolbarLinkActiveBackground": "rgba(194, 65, 12, 0.44)",
      "toolbarLinkActiveText": "#ffedd5",
      "toolbarLinkActiveShadow": "inset 0 1px 0 rgba(255, 237, 213, 0.36), 0 8px 16px rgba(120, 53, 15, 0.36)",
      "toolbarCaptureBorder": "var(--theme-accent-primary-button-border)",
      "toolbarCaptureBackground": "var(--theme-accent-primary-button-gradient)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(16, 185, 129, 0.92), rgba(251, 146, 60, 0.82))",
      "primaryButtonBorder": "rgba(52, 211, 153, 0.56)",
      "primaryButtonText": "#052e2b",
      "actionButtonBorder": "rgba(45, 212, 191, 0.46)",
      "actionButtonBackground": "rgba(236, 253, 245, 0.78)",
      "actionButtonText": "#065f46",
      "selectedBorder": "rgba(16, 185, 129, 0.62)",
      "selectedBackground": "rgba(45, 212, 191, 0.22)",
      "selectedText": "#065f46",
      "focusBorder": "rgba(251, 146, 60, 0.8)",
      "focusRing": "rgba(251, 146, 60, 0.34)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(52, 211, 153, 0.94), rgba(45, 212, 191, 0.86))",
      "sidebarPrimaryBorder": "rgba(94, 234, 212, 0.64)",
      "sidebarPrimaryText": "#022c22",
      "sidebarGhostBackground": "rgba(20, 184, 166, 0.22)",
      "sidebarGhostBorder": "rgba(94, 234, 212, 0.48)",
      "sidebarGhostText": "#ccfbf1",
      "rowActionBorder": "rgba(251, 146, 60, 0.58)",
      "rowActionBackground": "rgba(255, 237, 213, 0.74)",
      "rowActionText": "#9a3412"
    },
    "danger": {
      "softBackground": "rgba(255, 228, 230, 0.84)",
      "softBorder": "rgba(244, 63, 94, 0.44)",
      "softText": "#9f1239",
      "strongBackground": "rgba(190, 24, 93, 0.88)",
      "strongBorder": "rgba(251, 113, 133, 0.68)",
      "strongGradient": "linear-gradient(135deg, rgba(157, 23, 77, 0.92), rgba(244, 63, 94, 0.84))",
      "strongText": "#ffe4e6",
      "subtleText": "#be123c"
    }
  }
}
