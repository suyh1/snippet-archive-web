      "toolbarLinkBorder": "rgba(102, 125, 176, 0.6)",
      "toolbarLinkBackground": "rgba(18, 28, 56, 0.6)",
      "toolbarLinkText": "var(--theme-text-primary)",
      "toolbarLinkInsetShadow": "inset 0 1px 0 rgba(186, 212, 255, 0.3), inset 0 -1px 0 rgba(63, 80, 123, 0.3)",
      "toolbarLinkHoverBorder": "rgba(90, 162, 255, 0.7)",
      "toolbarLinkHoverBackground": "rgba(31, 50, 92, 0.74)",
      "toolbarLinkActiveBorder": "rgba(90, 162, 255, 0.78)",
      "toolbarLinkActiveBackground": "rgba(86, 116, 212, 0.44)",
