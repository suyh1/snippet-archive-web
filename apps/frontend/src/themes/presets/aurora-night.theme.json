{
  "schemaVersion": 1,
  "meta": {
    "id": "aurora-night",
    "name": "Aurora Night",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Modern dark aurora theme with teal, cyan and violet glows."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Manrope', 'Plus Jakarta Sans', 'Avenir Next', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #060b18 0%, #0d1528 100%)",
      "appShellBackground": "radial-gradient(circle at 10% 8%, rgba(45, 212, 191, 0.24), transparent 40%), radial-gradient(circle at 84% 2%, rgba(56, 189, 248, 0.24), transparent 38%), radial-gradient(circle at 48% 100%, rgba(129, 140, 248, 0.2), transparent 46%), linear-gradient(160deg, #060d1c 0%, #0d1730 52%, #111c38 100%)",
      "sidebarBackground": "radial-gradient(circle at 12% 12%, rgba(45, 212, 191, 0.2), transparent 44%), linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(15, 23, 42, 0.94))",
      "sidebarText": "#dbeafe",
      "sidebarBorder": "rgba(56, 189, 248, 0.35)"
    },
    "text": {
      "primary": "#e2e8f0",
      "secondary": "#cbd5e1",
      "tertiary": "#94a3b8",
      "inverse": "#0b1220",
      "accent": "#22d3ee",
      "muted": "#64748b",
      "danger": "#991b1b",
      "dangerStrong": "#7f1d1d"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(15, 23, 42, 0.74), rgba(15, 118, 110, 0.22))",
      "glassPanelBorder": "rgba(56, 189, 248, 0.32)",
      "glassPanelShadow": "0 20px 40px rgba(2, 6, 23, 0.46)",
      "glassCardBackground": "linear-gradient(140deg, rgba(15, 23, 42, 0.78), rgba(30, 64, 175, 0.2))",
      "glassTileBackground": "linear-gradient(145deg, rgba(15, 23, 42, 0.76), rgba(30, 64, 175, 0.16))",
      "glassTileBorder": "rgba(56, 189, 248, 0.38)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(15, 23, 42, 0.84), rgba(14, 116, 144, 0.3))",
      "ghostButtonBackground": "rgba(15, 23, 42, 0.6)",
      "neutralButtonBackground": "rgba(15, 23, 42, 0.74)",
      "neutralButtonBorder": "rgba(56, 189, 248, 0.45)",
      "inputBackground": "rgba(15, 23, 42, 0.84)",
      "inputBorder": "rgba(56, 189, 248, 0.44)",
      "codeTagBackground": "rgba(56, 189, 248, 0.24)",
      "statusbarBackground": "rgba(15, 23, 42, 0.86)",
      "statusbarBorder": "rgba(56, 189, 248, 0.34)",
      "emptyStateBackground": "rgba(255, 255, 255, 0.45)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(34, 211, 238, 0.2)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(129, 140, 248, 0.24)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(34, 211, 238, 0.16)",
      "rootDropzoneActiveBackground": "rgba(129, 140, 248, 0.22)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(2, 6, 23, 0.66)",
      "overlayStrongBackground": "rgba(2, 6, 23, 0.62)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(2, 6, 23, 0.92), rgba(13, 23, 43, 0.9))",
      "toastBorder": "rgba(148, 163, 184, 0.35)",
      "toastShadow": "0 14px 28px rgba(15, 23, 42, 0.28)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(34, 211, 238, 0.9), rgba(56, 189, 248, 0.84))",
      "primaryButtonBorder": "rgba(34, 211, 238, 0.58)",
      "primaryButtonText": "#06202f",
      "actionButtonBorder": "rgba(56, 189, 248, 0.48)",
      "actionButtonBackground": "rgba(15, 23, 42, 0.72)",
      "actionButtonText": "#bae6fd",
      "selectedBorder": "rgba(34, 211, 238, 0.62)",
      "selectedBackground": "rgba(34, 211, 238, 0.2)",
      "selectedText": "#67e8f9",
      "focusBorder": "rgba(129, 140, 248, 0.72)",
      "focusRing": "rgba(129, 140, 248, 0.4)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(45, 212, 191, 0.9), rgba(56, 189, 248, 0.84))",
      "sidebarPrimaryBorder": "rgba(34, 211, 238, 0.62)",
      "sidebarPrimaryText": "#052e3d",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
      "sidebarGhostBorder": "rgba(186, 230, 253, 0.36)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(56, 189, 248, 0.58)",
      "rowActionBackground": "rgba(14, 165, 233, 0.16)",
      "rowActionText": "#0f172a"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
  }
}
