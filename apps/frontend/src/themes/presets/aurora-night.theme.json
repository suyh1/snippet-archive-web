      "selectedText": "#67e8f9",
      "focusBorder": "rgba(129, 140, 248, 0.72)",
      "focusRing": "rgba(129, 140, 248, 0.4)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(45, 212, 191, 0.9), rgba(56, 189, 248, 0.84))",
      "sidebarPrimaryBorder": "rgba(34, 211, 238, 0.62)",
      "sidebarPrimaryText": "#052e3d",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
