      "primaryButtonText": "#06202f",
      "actionButtonBorder": "rgba(56, 189, 248, 0.48)",
      "actionButtonBackground": "rgba(15, 23, 42, 0.72)",
      "actionButtonText": "#bae6fd",
      "selectedBorder": "rgba(34, 211, 238, 0.62)",
