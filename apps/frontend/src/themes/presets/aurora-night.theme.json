{
  "schemaVersion": 1,
  "meta": {
    "id": "aurora-night",
    "name": "Aurora Night",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Modern dark aurora theme with teal, cyan and violet glows."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Manrope', 'Plus Jakarta Sans', 'Avenir Next', sans-serif",
