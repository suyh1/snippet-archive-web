{
  "schemaVersion": 1,
  "meta": {
    "id": "mono-minimal",
    "name": "Mono Minimal",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Minimal monochrome system theme for focused editing."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'IBM Plex Sans', 'Noto Sans SC', 'Segoe UI', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #fafafa 0%, #efefef 100%)",
      "appShellBackground": "radial-gradient(circle at 14% 8%, rgba(115, 115, 115, 0.14), transparent 42%), radial-gradient(circle at 86% 2%, rgba(163, 163, 163, 0.16), transparent 38%), linear-gradient(160deg, #f5f5f5 0%, #ededed 52%, #e7e7e7 100%)",
      "sidebarBackground": "linear-gradient(180deg, rgba(17, 24, 39, 0.97), rgba(31, 41, 55, 0.93))",
      "sidebarText": "#e5e7eb",
      "sidebarBorder": "rgba(107, 114, 128, 0.46)"
    },
    "text": {
      "primary": "#111827",
      "secondary": "#374151",
      "tertiary": "#4b5563",
      "inverse": "#f8fafc",
      "accent": "#374151",
      "muted": "#6b7280",
      "danger": "#991b1b",
      "dangerStrong": "#7f1d1d"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(255, 255, 255, 0.78), rgba(229, 231, 235, 0.5))",
      "glassPanelBorder": "rgba(209, 213, 219, 0.7)",
      "glassPanelShadow": "0 16px 32px rgba(15, 23, 42, 0.1)",
      "glassCardBackground": "linear-gradient(140deg, rgba(255, 255, 255, 0.84), rgba(243, 244, 246, 0.62))",
      "glassTileBackground": "linear-gradient(145deg, rgba(255, 255, 255, 0.84), rgba(243, 244, 246, 0.6))",
      "glassTileBorder": "rgba(255, 255, 255, 0.65)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(229, 231, 235, 0.58), rgba(243, 244, 246, 0.44))",
      "ghostButtonBackground": "rgba(255, 255, 255, 0.76)",
      "neutralButtonBackground": "rgba(248, 250, 252, 0.74)",
      "neutralButtonBorder": "rgba(156, 163, 175, 0.56)",
      "inputBackground": "rgba(255, 255, 255, 0.84)",
      "inputBorder": "rgba(156, 163, 175, 0.55)",
      "codeTagBackground": "rgba(209, 213, 219, 0.4)",
      "statusbarBackground": "rgba(248, 250, 252, 0.66)",
      "statusbarBorder": "rgba(148, 163, 184, 0.3)",
      "emptyStateBackground": "rgba(255, 255, 255, 0.45)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(186, 230, 253, 0.55)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(191, 219, 254, 0.56)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(224, 242, 254, 0.45)",
      "rootDropzoneActiveBackground": "rgba(186, 230, 253, 0.6)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(7, 11, 28, 0.45)",
      "overlayStrongBackground": "rgba(15, 23, 42, 0.42)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.85))",
      "toastBorder": "rgba(148, 163, 184, 0.35)",
      "toastShadow": "0 14px 28px rgba(15, 23, 42, 0.28)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(55, 65, 81, 0.92), rgba(75, 85, 99, 0.84))",
      "primaryButtonBorder": "rgba(75, 85, 99, 0.62)",
      "primaryButtonText": "#f9fafb",
      "actionButtonBorder": "rgba(156, 163, 175, 0.62)",
      "actionButtonBackground": "rgba(243, 244, 246, 0.84)",
      "actionButtonText": "#111827",
      "selectedBorder": "rgba(75, 85, 99, 0.62)",
      "selectedBackground": "rgba(156, 163, 175, 0.2)",
      "selectedText": "#111827",
      "focusBorder": "rgba(75, 85, 99, 0.75)",
      "focusRing": "rgba(107, 114, 128, 0.42)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(156, 163, 175, 0.92), rgba(107, 114, 128, 0.88))",
      "sidebarPrimaryBorder": "rgba(156, 163, 175, 0.72)",
      "sidebarPrimaryText": "#111827",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
      "sidebarGhostBorder": "rgba(186, 230, 253, 0.36)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(56, 189, 248, 0.58)",
      "rowActionBackground": "rgba(14, 165, 233, 0.16)",
      "rowActionText": "#0f172a"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
  }
}
