{
  "schemaVersion": 1,
  "meta": {
    "id": "tokyo-neon",
    "name": "Tokyo Neon",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Vibrant cyberpunk dark theme with cyan and magenta accents."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Manrope', 'Plus Jakarta Sans', 'Avenir Next', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #0a0f1f 0%, #14182d 100%)",
      "appShellBackground": "radial-gradient(circle at 12% 6%, rgba(34, 211, 238, 0.28), transparent 38%), radial-gradient(circle at 88% 2%, rgba(217, 70, 239, 0.24), transparent 36%), radial-gradient(circle at 52% 100%, rgba(59, 130, 246, 0.24), transparent 44%), linear-gradient(160deg, #0b1120 0%, #11162a 52%, #161a34 100%)",
      "sidebarBackground": "radial-gradient(circle at 18% 14%, rgba(6, 182, 212, 0.24), transparent 45%), radial-gradient(circle at 82% 100%, rgba(217, 70, 239, 0.18), transparent 42%), linear-gradient(180deg, rgba(12, 15, 36, 0.98), rgba(27, 23, 54, 0.94))",
      "sidebarText": "#e0e7ff",
      "sidebarBorder": "rgba(129, 140, 248, 0.4)"
    },
    "text": {
      "primary": "#e2e8f0",
      "secondary": "#c7d2fe",
      "tertiary": "#a5b4fc",
      "inverse": "#0b1020",
      "accent": "#22d3ee",
      "muted": "#818cf8",
      "danger": "#fb7185",
      "dangerStrong": "#fda4af"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(30, 27, 75, 0.72), rgba(15, 23, 42, 0.62))",
      "glassPanelBorder": "rgba(129, 140, 248, 0.45)",
      "glassPanelShadow": "0 20px 38px rgba(10, 10, 32, 0.44)",
      "glassCardBackground": "linear-gradient(140deg, rgba(30, 41, 59, 0.76), rgba(49, 46, 129, 0.54))",
      "glassTileBackground": "linear-gradient(145deg, rgba(49, 46, 129, 0.64), rgba(30, 41, 59, 0.54))",
      "glassTileBorder": "rgba(129, 140, 248, 0.5)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(49, 46, 129, 0.76), rgba(30, 41, 59, 0.62))",
      "ghostButtonBackground": "rgba(49, 46, 129, 0.46)",
      "neutralButtonBackground": "rgba(30, 41, 59, 0.8)",
      "neutralButtonBorder": "rgba(129, 140, 248, 0.6)",
      "inputBackground": "rgba(15, 23, 42, 0.86)",
      "inputBorder": "rgba(129, 140, 248, 0.56)",
      "codeTagBackground": "rgba(129, 140, 248, 0.34)",
