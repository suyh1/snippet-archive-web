      "rowActiveBackground": "rgba(34, 211, 238, 0.24)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(217, 70, 239, 0.24)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(34, 211, 238, 0.2)",
      "rootDropzoneActiveBackground": "rgba(217, 70, 239, 0.26)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(5, 8, 28, 0.7)",
      "overlayStrongBackground": "rgba(5, 8, 28, 0.66)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(30, 27, 75, 0.9), rgba(15, 23, 42, 0.9))",
