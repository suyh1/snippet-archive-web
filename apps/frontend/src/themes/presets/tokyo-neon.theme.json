      "toolbarGlassBackdropFilter": "blur(28px) saturate(1.6) contrast(1.08)",
      "toolbarGlassShadow": "0 22px 44px rgba(4, 8, 18, 0.62), 0 0 24px rgba(33, 214, 255, 0.26), 0 0 26px rgba(236, 72, 255, 0.24), inset 0 1px 0 rgba(206, 248, 255, 0.34), inset 0 -1px 0 rgba(112, 64, 171, 0.28)",
      "toolbarGlassHighlightArc": "radial-gradient(104% 94% at 50% 100%, rgba(224, 255, 255, 0.52) 0%, rgba(224, 255, 255, 0.2) 34%, rgba(224, 255, 255, 0.08) 56%, rgba(224, 255, 255, 0) 74%)",
      "toolbarGlassTintOverlay": "radial-gradient(circle at 16% 84%, rgba(52, 228, 255, 0.24), rgba(52, 228, 255, 0) 44%), radial-gradient(circle at 86% 86%, rgba(236, 95, 255, 0.22), rgba(236, 95, 255, 0) 46%)",
      "toolbarTitleText": "var(--theme-text-secondary)",
      "toolbarLinkBorder": "rgba(82, 207, 240, 0.62)",
      "toolbarLinkBackground": "rgba(18, 24, 47, 0.58)",
      "toolbarLinkText": "var(--theme-text-primary)",
      "toolbarLinkInsetShadow": "inset 0 1px 0 rgba(181, 246, 255, 0.32), inset 0 -1px 0 rgba(112, 67, 176, 0.26)",
      "toolbarLinkHoverBorder": "rgba(67, 224, 255, 0.72)",
      "toolbarLinkHoverBackground": "rgba(27, 44, 84, 0.74)",
      "toolbarLinkActiveBorder": "rgba(67, 224, 255, 0.8)",
      "toolbarLinkActiveBackground": "rgba(157, 82, 255, 0.36)",
      "toolbarLinkActiveText": "var(--theme-accent-selected-text)",
      "toolbarLinkActiveShadow": "inset 0 1px 0 rgba(220, 250, 255, 0.44), 0 8px 18px rgba(20, 122, 171, 0.34)",
      "toolbarCaptureBorder": "var(--theme-accent-primary-button-border)",
      "toolbarCaptureBackground": "var(--theme-accent-primary-button-gradient)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(34, 211, 238, 0.92), rgba(217, 70, 239, 0.86))",
      "primaryButtonBorder": "rgba(34, 211, 238, 0.66)",
      "primaryButtonText": "#0b1020",
      "actionButtonBorder": "rgba(129, 140, 248, 0.62)",
      "actionButtonBackground": "rgba(30, 41, 59, 0.74)",
      "actionButtonText": "#e0e7ff",
      "selectedBorder": "rgba(34, 211, 238, 0.7)",
      "selectedBackground": "rgba(34, 211, 238, 0.24)",
      "selectedText": "#67e8f9",
      "focusBorder": "rgba(217, 70, 239, 0.76)",
      "focusRing": "rgba(217, 70, 239, 0.46)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(34, 211, 238, 0.9), rgba(59, 130, 246, 0.86))",
      "sidebarPrimaryBorder": "rgba(34, 211, 238, 0.7)",
      "sidebarPrimaryText": "#082f49",
      "sidebarGhostBackground": "rgba(79, 70, 229, 0.4)",
      "sidebarGhostBorder": "rgba(165, 180, 252, 0.56)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(34, 211, 238, 0.64)",
      "rowActionBackground": "rgba(14, 116, 144, 0.4)",
      "rowActionText": "#cffafe"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
