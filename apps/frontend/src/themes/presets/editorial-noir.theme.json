{
  "schemaVersion": 1,
  "meta": {
    "id": "editorial-noir",
    "name": "Editorial Noir",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "编辑感黑金主题，强调高对比与杂志级层次。"
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Libre Bodoni', 'Public Sans', 'Noto Sans SC', sans-serif",
