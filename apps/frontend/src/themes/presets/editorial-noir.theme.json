      "actionButtonBorder": "rgba(245, 158, 11, 0.46)",
      "actionButtonBackground": "rgba(44, 33, 24, 0.72)",
      "actionButtonText": "#fef3c7",
      "selectedBorder": "rgba(245, 158, 11, 0.62)",
