      "toolbarLinkActiveBorder": "rgba(250, 204, 21, 0.74)",
      "toolbarLinkActiveBackground": "rgba(120, 53, 15, 0.56)",
      "toolbarLinkActiveText": "var(--theme-accent-selected-text)",
      "toolbarLinkActiveShadow": "inset 0 1px 0 rgba(255, 240, 211, 0.36), 0 8px 18px rgba(88, 57, 21, 0.46)",
