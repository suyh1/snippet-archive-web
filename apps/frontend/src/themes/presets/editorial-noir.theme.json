      "toolbarGlassTintOverlay": "radial-gradient(circle at 16% 84%, rgba(238, 112, 166, 0.2), rgba(238, 112, 166, 0) 44%), radial-gradient(circle at 84% 86%, rgba(247, 190, 61, 0.18), rgba(247, 190, 61, 0) 46%)",
