{
  "schemaVersion": 1,
  "meta": {
    "id": "sunset-ui",
    "name": "Sunset UI",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Warm modern gradient theme with orange-pink accents."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Manrope', 'Plus Jakarta Sans', 'Avenir Next', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #fff7ed 0%, #ffe7d6 100%)",
      "appShellBackground": "radial-gradient(circle at 10% 8%, rgba(251, 146, 60, 0.28), transparent 42%), radial-gradient(circle at 88% 2%, rgba(244, 114, 182, 0.22), transparent 38%), radial-gradient(circle at 48% 100%, rgba(253, 186, 116, 0.2), transparent 44%), linear-gradient(160deg, #ffedd5 0%, #ffe4d6 50%, #ffe7eb 100%)",
      "sidebarBackground": "radial-gradient(circle at 14% 10%, rgba(251, 146, 60, 0.24), transparent 44%), linear-gradient(180deg, rgba(124, 45, 18, 0.96), rgba(157, 23, 77, 0.9))",
      "sidebarText": "#ffe4e6",
      "sidebarBorder": "rgba(253, 186, 116, 0.42)"
    },
    "text": {
      "primary": "#7c2d12",
      "secondary": "#9a3412",
      "tertiary": "#be123c",
      "inverse": "#f8fafc",
      "accent": "#ea580c",
      "muted": "#9a3412",
      "danger": "#991b1b",
      "dangerStrong": "#7f1d1d"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(255, 251, 245, 0.74), rgba(254, 215, 170, 0.42))",
      "glassPanelBorder": "rgba(255, 255, 255, 0.68)",
      "glassPanelShadow": "0 16px 32px rgba(15, 23, 42, 0.1)",
      "glassCardBackground": "linear-gradient(140deg, rgba(255, 251, 245, 0.8), rgba(254, 215, 170, 0.5))",
      "glassTileBackground": "linear-gradient(145deg, rgba(255, 255, 255, 0.74), rgba(224, 242, 254, 0.45))",
      "glassTileBorder": "rgba(255, 255, 255, 0.65)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(253, 186, 116, 0.46), rgba(251, 207, 232, 0.34))",
      "ghostButtonBackground": "rgba(255, 255, 255, 0.76)",
      "neutralButtonBackground": "rgba(248, 250, 252, 0.74)",
      "neutralButtonBorder": "rgba(148, 163, 184, 0.55)",
      "inputBackground": "rgba(255, 255, 255, 0.84)",
      "inputBorder": "rgba(148, 163, 184, 0.55)",
      "codeTagBackground": "rgba(148, 163, 184, 0.18)",
      "statusbarBackground": "rgba(248, 250, 252, 0.66)",
      "statusbarBorder": "rgba(148, 163, 184, 0.3)",
      "emptyStateBackground": "rgba(255, 255, 255, 0.45)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(186, 230, 253, 0.55)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(191, 219, 254, 0.56)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(224, 242, 254, 0.45)",
      "rootDropzoneActiveBackground": "rgba(186, 230, 253, 0.6)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(7, 11, 28, 0.45)",
      "overlayStrongBackground": "rgba(15, 23, 42, 0.42)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.85))",
      "toastBorder": "rgba(148, 163, 184, 0.35)",
      "toastShadow": "0 14px 28px rgba(15, 23, 42, 0.28)",
      "toolbarGlassBorder": "rgba(222, 160, 136, 0.48)",
      "toolbarGlassBackground": "radial-gradient(128% 188% at 12% -30%, rgba(255, 149, 101, 0.3) 0%, rgba(255, 149, 101, 0) 54%), radial-gradient(136% 196% at 90% -46%, rgba(244, 114, 182, 0.24) 0%, rgba(244, 114, 182, 0) 56%), var(--theme-surface-glass-header-background)",
      "toolbarGlassBackdropFilter": "blur(26px) saturate(1.38) contrast(1.05)",
      "toolbarGlassShadow": "0 20px 40px rgba(58, 24, 20, 0.38), 0 8px 20px rgba(171, 86, 59, 0.24), inset 0 1px 0 rgba(255, 232, 224, 0.42), inset 0 -1px 0 rgba(174, 102, 82, 0.28)",
      "toolbarGlassHighlightArc": "radial-gradient(103% 93% at 50% 100%, rgba(255, 236, 226, 0.6) 0%, rgba(255, 236, 226, 0.24) 36%, rgba(255, 236, 226, 0.08) 56%, rgba(255, 236, 226, 0) 74%)",
      "toolbarGlassTintOverlay": "radial-gradient(circle at 16% 84%, rgba(255, 152, 94, 0.22), rgba(255, 152, 94, 0) 44%), radial-gradient(circle at 86% 86%, rgba(238, 104, 173, 0.2), rgba(238, 104, 173, 0) 46%)",
      "toolbarTitleText": "var(--theme-text-secondary)",
      "toolbarLinkBorder": "rgba(214, 148, 120, 0.6)",
      "toolbarLinkBackground": "rgba(255, 238, 230, 0.52)",
      "toolbarLinkText": "var(--theme-text-primary)",
      "toolbarLinkInsetShadow": "inset 0 1px 0 rgba(255, 246, 241, 0.44), inset 0 -1px 0 rgba(165, 95, 78, 0.22)",
      "toolbarLinkHoverBorder": "rgba(239, 124, 82, 0.62)",
      "toolbarLinkHoverBackground": "rgba(255, 214, 195, 0.54)",
      "toolbarLinkActiveBorder": "rgba(236, 112, 69, 0.7)",
      "toolbarLinkActiveBackground": "rgba(244, 160, 121, 0.52)",
      "toolbarLinkActiveText": "var(--theme-accent-selected-text)",
      "toolbarLinkActiveShadow": "inset 0 1px 0 rgba(255, 246, 240, 0.52), 0 7px 15px rgba(139, 69, 53, 0.3)",
      "toolbarCaptureBorder": "var(--theme-accent-primary-button-border)",
      "toolbarCaptureBackground": "var(--theme-accent-primary-button-gradient)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(249, 115, 22, 0.92), rgba(244, 114, 182, 0.84))",
      "primaryButtonBorder": "rgba(249, 115, 22, 0.6)",
      "primaryButtonText": "#f8fafc",
      "actionButtonBorder": "rgba(148, 163, 184, 0.48)",
      "actionButtonBackground": "rgba(241, 245, 249, 0.7)",
      "actionButtonText": "#334155",
      "selectedBorder": "rgba(249, 115, 22, 0.56)",
      "selectedBackground": "rgba(249, 115, 22, 0.16)",
      "selectedText": "#c2410c",
      "focusBorder": "rgba(56, 189, 248, 0.85)",
      "focusRing": "rgba(56, 189, 248, 0.35)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(251, 146, 60, 0.92), rgba(244, 114, 182, 0.84))",
      "sidebarPrimaryBorder": "rgba(251, 146, 60, 0.64)",
      "sidebarPrimaryText": "#7c2d12",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
      "sidebarGhostBorder": "rgba(186, 230, 253, 0.36)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(56, 189, 248, 0.58)",
      "rowActionBackground": "rgba(14, 165, 233, 0.16)",
      "rowActionText": "#0f172a"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
  }
}
