{
  "schemaVersion": 1,
  "meta": {
    "id": "graphite-pro",
    "name": "Graphite Pro",
    "version": "1.1.0",
    "author": "Snippet Archive",
    "description": "石墨专业主题，深色基底强化信息密度和稳定感。"
  },
  "modules": {
