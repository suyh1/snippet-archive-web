      "toolbarLinkHoverBorder": "rgba(96, 163, 250, 0.68)",
      "toolbarLinkHoverBackground": "rgba(34, 53, 84, 0.72)",
      "toolbarLinkActiveBorder": "rgba(96, 163, 250, 0.74)",
      "toolbarLinkActiveBackground": "rgba(40, 87, 170, 0.44)",
