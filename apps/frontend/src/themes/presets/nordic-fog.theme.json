{
  "schemaVersion": 1,
  "meta": {
    "id": "nordic-fog",
    "name": "Nordic Fog",
    "version": "1.0.0",
    "author": "Snippet Archive",
    "description": "Cool and calm light theme inspired by Nordic UI palettes."
  },
  "modules": {
    "layout": {
      "appFontFamily": "'Manrope', 'Plus Jakarta Sans', 'Avenir Next', sans-serif",
      "bodyBackground": "linear-gradient(180deg, #f8fbff 0%, #edf3ff 100%)",
      "appShellBackground": "radial-gradient(circle at 12% 10%, rgba(96, 165, 250, 0.18), transparent 42%), radial-gradient(circle at 86% 4%, rgba(148, 163, 184, 0.2), transparent 38%), radial-gradient(circle at 48% 100%, rgba(125, 211, 252, 0.16), transparent 46%), linear-gradient(160deg, #eaf1fb 0%, #e8eef8 54%, #eaf2ff 100%)",
      "sidebarBackground": "radial-gradient(circle at 16% 14%, rgba(148, 163, 184, 0.2), transparent 46%), radial-gradient(circle at 82% 100%, rgba(96, 165, 250, 0.16), transparent 42%), linear-gradient(180deg, rgba(30, 41, 59, 0.95), rgba(51, 65, 85, 0.92))",
      "sidebarText": "#e2e8f0",
      "sidebarBorder": "rgba(148, 163, 184, 0.28)"
    },
    "text": {
      "primary": "#1e293b",
      "secondary": "#334155",
      "tertiary": "#475569",
      "inverse": "#f8fafc",
      "accent": "#2563eb",
      "muted": "#94a3b8",
      "danger": "#991b1b",
      "dangerStrong": "#7f1d1d"
    },
    "surface": {
      "glassPanelBackground": "linear-gradient(150deg, rgba(255, 255, 255, 0.74), rgba(226, 232, 240, 0.46))",
      "glassPanelBorder": "rgba(255, 255, 255, 0.68)",
      "glassPanelShadow": "0 16px 32px rgba(15, 23, 42, 0.1)",
      "glassCardBackground": "linear-gradient(140deg, rgba(255, 255, 255, 0.8), rgba(230, 238, 250, 0.6))",
      "glassTileBackground": "linear-gradient(145deg, rgba(255, 255, 255, 0.74), rgba(224, 242, 254, 0.45))",
      "glassTileBorder": "rgba(255, 255, 255, 0.65)",
      "glassHeaderBackground": "linear-gradient(120deg, rgba(219, 234, 254, 0.56), rgba(191, 219, 254, 0.32))",
      "ghostButtonBackground": "rgba(255, 255, 255, 0.84)",
      "neutralButtonBackground": "rgba(248, 250, 252, 0.8)",
      "neutralButtonBorder": "rgba(148, 163, 184, 0.55)",
      "inputBackground": "rgba(255, 255, 255, 0.84)",
      "inputBorder": "rgba(148, 163, 184, 0.55)",
      "codeTagBackground": "rgba(148, 163, 184, 0.18)",
      "statusbarBackground": "rgba(248, 250, 252, 0.66)",
      "statusbarBorder": "rgba(148, 163, 184, 0.3)",
      "emptyStateBackground": "rgba(255, 255, 255, 0.45)",
      "rowBorder": "rgba(226, 232, 240, 0.72)",
      "rowActiveBackground": "rgba(186, 230, 253, 0.55)",
      "rowDraftBackground": "rgba(240, 249, 255, 0.82)",
      "rowRenameBackground": "rgba(236, 254, 255, 0.85)",
      "rowDropActiveBackground": "rgba(191, 219, 254, 0.56)",
      "rowDropInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "rootDropzoneBackground": "rgba(224, 242, 254, 0.45)",
      "rootDropzoneActiveBackground": "rgba(186, 230, 253, 0.6)",
      "rootDropzoneInvalidBackground": "rgba(254, 226, 226, 0.66)",
      "overlayBackground": "rgba(7, 11, 28, 0.45)",
      "overlayStrongBackground": "rgba(15, 23, 42, 0.42)",
      "overlayBlur": "blur(8px)",
      "overlaySoftBlur": "blur(4px)",
      "toastBackground": "linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 41, 59, 0.85))",
      "toastBorder": "rgba(148, 163, 184, 0.35)",
      "toastShadow": "0 14px 28px rgba(15, 23, 42, 0.28)",
      "toolbarGlassBorder": "rgba(203, 223, 237, 0.5)",
      "toolbarGlassBackground": "radial-gradient(130% 190% at 10% -30%, rgba(140, 198, 255, 0.22) 0%, rgba(140, 198, 255, 0) 56%), radial-gradient(140% 200% at 92% -44%, rgba(146, 167, 210, 0.2) 0%, rgba(146, 167, 210, 0) 58%), var(--theme-surface-glass-header-background)",
      "toolbarGlassBackdropFilter": "blur(24px) saturate(1.3) contrast(1.05)",
      "toolbarGlassShadow": "0 18px 36px rgba(12, 24, 40, 0.34), 0 6px 16px rgba(84, 125, 166, 0.22), inset 0 1px 0 rgba(236, 244, 252, 0.42), inset 0 -1px 0 rgba(128, 154, 186, 0.24)",
      "toolbarGlassHighlightArc": "radial-gradient(102% 92% at 50% 100%, rgba(249, 253, 255, 0.56) 0%, rgba(249, 253, 255, 0.24) 38%, rgba(249, 253, 255, 0.08) 58%, rgba(249, 253, 255, 0) 76%)",
      "toolbarGlassTintOverlay": "radial-gradient(circle at 18% 82%, rgba(128, 191, 246, 0.16), rgba(128, 191, 246, 0) 46%), radial-gradient(circle at 86% 84%, rgba(155, 188, 222, 0.14), rgba(155, 188, 222, 0) 44%)",
      "toolbarTitleText": "var(--theme-text-secondary)",
      "toolbarLinkBorder": "rgba(150, 173, 197, 0.56)",
      "toolbarLinkBackground": "rgba(243, 248, 252, 0.5)",
      "toolbarLinkText": "var(--theme-text-primary)",
      "toolbarLinkInsetShadow": "inset 0 1px 0 rgba(245, 250, 255, 0.38), inset 0 -1px 0 rgba(132, 157, 185, 0.2)",
      "toolbarLinkHoverBorder": "rgba(104, 148, 194, 0.58)",
      "toolbarLinkHoverBackground": "rgba(206, 227, 245, 0.42)",
      "toolbarLinkActiveBorder": "rgba(93, 141, 189, 0.6)",
      "toolbarLinkActiveBackground": "rgba(125, 174, 223, 0.28)",
      "toolbarLinkActiveText": "var(--theme-accent-selected-text)",
      "toolbarLinkActiveShadow": "inset 0 1px 0 rgba(247, 252, 255, 0.46), 0 6px 14px rgba(76, 116, 155, 0.28)",
      "toolbarCaptureBorder": "var(--theme-accent-primary-button-border)",
      "toolbarCaptureBackground": "var(--theme-accent-primary-button-gradient)"
    },
    "accent": {
      "primaryButtonGradient": "linear-gradient(130deg, rgba(37, 99, 235, 0.9), rgba(56, 189, 248, 0.84))",
      "primaryButtonBorder": "rgba(37, 99, 235, 0.5)",
      "primaryButtonText": "#f8fafc",
      "actionButtonBorder": "rgba(148, 163, 184, 0.48)",
      "actionButtonBackground": "rgba(241, 245, 249, 0.7)",
      "actionButtonText": "#334155",
      "selectedBorder": "rgba(37, 99, 235, 0.52)",
      "selectedBackground": "rgba(59, 130, 246, 0.16)",
      "selectedText": "#1d4ed8",
      "focusBorder": "rgba(56, 189, 248, 0.85)",
      "focusRing": "rgba(56, 189, 248, 0.35)",
      "sidebarPrimaryGradient": "linear-gradient(135deg, rgba(96, 165, 250, 0.95), rgba(56, 189, 248, 0.86))",
      "sidebarPrimaryBorder": "rgba(56, 189, 248, 0.55)",
      "sidebarPrimaryText": "#082f49",
      "sidebarGhostBackground": "rgba(255, 255, 255, 0.12)",
      "sidebarGhostBorder": "rgba(186, 230, 253, 0.36)",
      "sidebarGhostText": "#dbeafe",
      "rowActionBorder": "rgba(56, 189, 248, 0.58)",
      "rowActionBackground": "rgba(14, 165, 233, 0.16)",
      "rowActionText": "#0f172a"
    },
    "danger": {
      "softBackground": "rgba(254, 226, 226, 0.78)",
      "softBorder": "rgba(248, 113, 113, 0.4)",
      "softText": "#991b1b",
      "strongBackground": "rgba(220, 38, 38, 0.86)",
      "strongBorder": "rgba(248, 113, 113, 0.75)",
      "strongGradient": "linear-gradient(135deg, rgba(220, 38, 38, 0.92), rgba(248, 113, 113, 0.86))",
      "strongText": "#fef2f2",
      "subtleText": "#b91c1c"
    }
  }
}
