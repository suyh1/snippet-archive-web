generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id           String          @id @default(uuid())
  title        String
  description  String          @default("")
  tags         String[]
  starred      Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lastOpenedAt DateTime?
  files        WorkspaceFile[]
}

model WorkspaceFile {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  path        String
  language    String
  content     String    @default("")
  tags        String[]  @default([])
  starred     Boolean   @default(false)
  kind        String
  order       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  revisions   WorkspaceFileRevision[]

  @@index([workspaceId])
  @@index([workspaceId, path])
  @@index([workspaceId, language])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, starred])
}

model WorkspaceFileRevision {
  id          String        @id @default(uuid())
  workspaceId String
  fileId      String
  file        WorkspaceFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  language    String
  content     String
  source      String
  summary     String        @default("")
  createdAt   DateTime      @default(now())

  @@index([fileId, createdAt])
  @@index([workspaceId, fileId, createdAt])
}
