{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snippet-archive.local/schemas/snippet-bundle.v1.schema.json",
  "title": "Snippet Archive Bundle v1",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "workspaces"],
  "properties": {
    "schemaVersion": {
      "const": "snippet-archive-bundle/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "workspaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "files"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "starred": { "type": "boolean" },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "path",
                "language",
                "content",
                "kind",
                "order"
              ],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 },
                "language": { "type": "string", "minLength": 1 },
                "content": { "type": "string" },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" },
                  "uniqueItems": true
                },
                "starred": { "type": "boolean" },
                "kind": { "type": "string", "minLength": 1 },
                "order": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
